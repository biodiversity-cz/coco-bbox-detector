# Zkopírujte na secret.yaml (nepřidávejte do gitu) a vyplňte hodnoty.
# kubectl apply -f secret.yaml
#
# Nebo z CLI:
# kubectl -n databots create secret generic herbarium-databots-secret \
#   --from-literal=DB_HOST=... \
#   --from-literal=DB_PORT=5432 \
#   ...
apiVersion: v1
kind: Secret
metadata:
  name: herbarium-databots-secret
  namespace: databots
type: Opaque
stringData:
  DB_HOST: "postgres.example.internal"
  DB_PORT: "5432"
  DB_DATABASE: "jacq_dev"
  DB_USER: "databot"
  DB_PASSWORD: "change-me"
  S3_ENDPOINT_URL: "https://minio.example.internal"
  S3_BUCKET: "thumbs1280"
  S3_ACCESS_KEY: "change-me"
  S3_SECRET_KEY: "change-me"
  # Volitelné pro coco-bbox-detector (jinak z config.yaml v image)
  # YOLO_DEVICE: "cpu"
  # OUTPUT_COCO_PATH: "/data/out/batch.coco.json"
